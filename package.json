{
  "name": "compaction-mcp",
  "version": "0.1.0",
  "description": "Portable MCP stdio server that brings Claude Code's /compact lifecycle to Copilot and local LLMs.",
  "type": "module",
  "bin": {
    "compaction-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "dev": "tsc --watch",
    "start": "node dist/index.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0"
  },
  "license": "MIT"
}
